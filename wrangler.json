{
  "$schema": "https://unpkg.com/wrangler@latest/config-schema.json",
  "name": "openpolsia",
  "main": "src/worker.ts",
  "compatibility_date": "2024-12-01",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": "./public"
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "openpolsia-db",
      "database_id": "b7167993-8a1c-4dd6-8a86-acce43d80389"
    }
  ],
  "routes": [
    { "custom_domain": true, "pattern": "www.openpolsia.com" },
    { "custom_domain": true, "pattern": "openpolsia.com" }
  ]
}
