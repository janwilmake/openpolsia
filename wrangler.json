{
  "$schema": "https://unpkg.com/wrangler@latest/config-schema.json",
  "name": "openpolsia",
  "main": "src/worker.ts",
  "compatibility_date": "2024-12-01",
  "compatibility_flags": ["nodejs_compat"],
  "durable_objects": {
    "bindings": [
      {
        "name": "COMPANY_DO",
        "class_name": "CompanyDO"
      }
    ]
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["CompanyDO"]
    }
  ],
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "openpolsia-db",
      "database_id": "b7167993-8a1c-4dd6-8a86-acce43d80389"
    }
  ],
  "observability": {
    "logs": { "enabled": false, "invocation_logs": true }
  },

  "env": {
    "prod": {
      "observability": {
        "logs": { "enabled": false, "invocation_logs": true }
      },
      "d1_databases": [
        {
          "binding": "DB",
          "database_name": "openpolsia-db",
          "database_id": "b7167993-8a1c-4dd6-8a86-acce43d80389"
        }
      ],
      "routes": [
        {
          "custom_domain": true,
          "pattern": "www.openpolsia.com"
        },
        {
          "custom_domain": true,
          "pattern": "openpolsia.com"
        },
        {
          "zone_name": "openpolsia.com",
          "pattern": "*.openpolsia.com/*"
        }
      ],
      "durable_objects": {
        "bindings": [
          {
            "name": "COMPANY_DO",
            "class_name": "CompanyDO"
          }
        ]
      },
      "migrations": [
        {
          "tag": "v1",
          "new_sqlite_classes": ["CompanyDO"]
        }
      ]
    }
  }
}
